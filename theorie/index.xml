&lt;style&gt;
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
--bg: #f7f6f3;
--surface: #ffffff;
--surface-2: #f1f0ec;
--border: rgba(0,0,0,0.10);
