font-family: var(--mono);
font-size: 10px;
color: rgba(0,0,0,0.4);
text-align: center;
padding: 5px 3px 3px;
min-height: 44px;
transition: all 0.18s ease;
}
.pb2::after { content: ""; display: table; clear: both; }
/* code panel */
.lb-code {
