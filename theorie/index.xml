}
body {
font-family: var(--sans);
background: var(--bg);
color: var(--text-1);
min-height: 100vh;
padding: 2.5rem 1.5rem;
}
.wrapper { max-width: 920px; margin: 0 auto; }
.lb-header { margin-bottom: 1.5rem; }
